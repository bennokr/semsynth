{
  "@context": "https://w3id.org/semmap/context/v1",
  "@type": ["disco:LogicalDataSet", "dsv:Dataset", "dcat:Dataset"],
  "dct:title": "Heart Disease (UCI id 45)",
  "dct:description": "4 databases: Cleveland, Hungary, Switzerland, and the VA Long Beach",
  "dct:license": "https://creativecommons.org/publicdomain/zero/1.0/",
  "datasetSchema": {
    "columns": [
      {
        "name": "age",
        "titles": "Age",
        "columnProperty": {
          "summaryStatistics": {"statisticalDataType": "dsv:QuantitativeDataType"},
          "valueType": "xsd:integer",
          "hasUnit": {"exactMatch": ["unit:YR"], "ucumCode": "a"},
          "source": "https://loinc.org/30525-0"
        }
      },
      {
        "name": "sex",
        "titles": "Administrative sex",
        "columnProperty": {
          "summaryStatistics": {"statisticalDataType": "dsv:NominalDataType"},
          "source": "https://docs.snomed.org/implementation-guides/snomed-ct-guide-for-covid-19/2-coding-covid-19-related-data/2.2-patient-demographics",
          "hasCodeBook": {
            "hasTopConcept": [
              { "notation": "0", "prefLabel": "female", "exactMatch": ["http://snomed.info/id/248152002"] },
              { "notation": "1", "prefLabel": "male",   "exactMatch": ["http://snomed.info/id/248153007"] }
            ]
          }
        }
      },
      {
        "name": "cp",
        "titles": "Chest pain type",
        "columnProperty": {
          "summaryStatistics": {"statisticalDataType": "dsv:NominalDataType"},
          "source": "https://dicom.nema.org/medical/dicom/current/output/chtml/part16/sect_CID_3202.html",
          "hasCodeBook": {
            "source": "https://dicom.nema.org/medical/dicom/current/output/chtml/part16/sect_CID_3202.html",
            "hasTopConcept": [
              { "notation": "1", "prefLabel": "Typical angina",          "exactMatch": ["http://snomed.info/id/429559004"] },
              { "notation": "2", "prefLabel": "Atypical angina",          "exactMatch": ["http://snomed.info/id/371807002"] },
              { "notation": "3", "prefLabel": "Non-cardiac chest pain",   "exactMatch": ["http://snomed.info/id/274668005"] },
              { "notation": "4", "prefLabel": "Asymptomatic",             "exactMatch": ["http://snomed.info/id/161971004"] }
            ]
          }
        }
      },
      {
        "name": "fbs",
        "titles": "Fasting blood sugar >120 mg/dL (indicator)",
        "columnProperty": {
          "summaryStatistics": {"statisticalDataType": "dsv:NominalDataType"},
          "source": "https://loinc.org/2345-7",
          "hasCodeBook": {
            "source": "https://loinc.org/2345-7",
            "hasTopConcept": [
              { "notation": "0", "prefLabel": "≤120 mg/dL" },
              { "notation": "1", "prefLabel": ">120 mg/dL" }
            ]
          }
        }
      },
      {
        "name": "trestbps",
        "titles": "Resting systolic blood pressure",
        "columnProperty": {
          "summaryStatistics": {"statisticalDataType": "dsv:QuantitativeDataType"},
          "valueType": "xsd:integer",
          "hasUnit": {"exactMatch": ["unit:MilliM_HG"], "ucumCode": "mm[Hg]"},
          "source": "https://loinc.org/8480-6"
        }
      },
      {
        "name": "chol",
        "titles": "Total cholesterol",
        "columnProperty": {
          "summaryStatistics": {"statisticalDataType": "dsv:QuantitativeDataType"},
          "valueType": "xsd:integer",
          "hasUnit": {"exactMatch": ["unit:MilliGM-PER-DeciL"], "ucumCode": "mg/dL"},
          "source": "https://loinc.org/2093-3"
        }
      },
      {
        "name": "restecg",
        "titles": "Resting ECG result",
        "columnProperty": {
          "summaryStatistics": {"statisticalDataType": "dsv:NominalDataType"},
          "source": "https://cvquality.acc.org/docs/default-source/ncdr/data-collection/epdeviceimplant_v2-3_datadictionarycoders.pdf",
          "hasCodeBook": {
            "hasTopConcept": [
              { "notation": "0", "prefLabel": "normal",             "exactMatch": ["http://snomed.info/id/164854000"] },
              { "notation": "1", "prefLabel": "ST-T abnormality",   "exactMatch": ["http://snomed.info/id/428750005"] },
              { "notation": "2", "prefLabel": "LVH (Estes)",        "exactMatch": ["http://snomed.info/id/25488008"] }
            ]
          }
        }
      },
      {
        "name": "thalach",
        "titles": "Maximum heart rate achieved",
        "columnProperty": {
          "summaryStatistics": {"statisticalDataType": "dsv:QuantitativeDataType"},
          "valueType": "xsd:integer",
          "source": "https://loinc.org/101692-2"
        }
      },
      {
        "name": "exang",
        "titles": "Exercise-induced angina",
        "columnProperty": {
          "summaryStatistics": {"statisticalDataType": "dsv:NominalDataType"},
          "hasCodeBook": {
            "hasTopConcept": [
              { "notation": "0", "prefLabel": "no" },
              { "notation": "1", "prefLabel": "yes" }
            ]
          },
          "source": "https://archive.datadictionary.nhs.uk/DD%20Release%20June%202021/Covid19PRA/Coronary_Heart.html"
        }
      },
      {
        "name": "oldpeak",
        "titles": "ST depression vs rest (max during study)",
        "columnProperty": {
          "summaryStatistics": {"statisticalDataType": "dsv:QuantitativeDataType"},
          "valueType": "xsd:decimal",
          "source": "https://loinc.org/91546-2"
        }
      },
      {
        "name": "slope",
        "titles": "Slope of peak exercise ST segment",
        "columnProperty": {
          "summaryStatistics": {"statisticalDataType": "dsv:NominalDataType"},
          "hasCodeBook": {
            "hasTopConcept": [
              { "notation": "1", "prefLabel": "upsloping" },
              { "notation": "2", "prefLabel": "flat" },
              { "notation": "3", "prefLabel": "downsloping" }
            ]
          },
          "source": "https://dicom.nema.org/medical/dicom/current/output/chtml/part16/sect_CID_3233.html"
        }
      },
      {
        "name": "ca",
        "titles": "Number of major vessels (colored by fluoroscopy)",
        "columnProperty": {
          "summaryStatistics": {"statisticalDataType": "dsv:QuantitativeDataType"},
          "valueType": "xsd:integer"
        }
      },
      {
        "name": "thal",
        "titles": "Thallium perfusion test",
        "columnProperty": {
          "summaryStatistics": {"statisticalDataType": "dsv:NominalDataType"},
          "hasCodeBook": {
            "hasTopConcept": [
              { "notation": "3", "prefLabel": "normal",            "exactMatch": ["http://snomed.info/id/371801000"] },
              { "notation": "6", "prefLabel": "fixed defect",      "exactMatch": ["http://snomed.info/id/371918009"] },
              { "notation": "7", "prefLabel": "reversible defect", "exactMatch": ["http://snomed.info/id/371920002"] }
            ]
          }
        }
      },
      {
        "name": "num",
        "titles": "Angiographic disease status",
        "columnProperty": {
          "summaryStatistics": {"statisticalDataType": "dsv:NominalDataType"},
          "hasCodeBook": {
            "hasTopConcept": [
              { "notation": "0", "prefLabel": "<50% narrowing" },
              { "notation": "1", "prefLabel": "≥50% narrowing" }
            ]
          },
          "source": "https://purl.bioontology.org/ontology/SNOMEDCT/233970002"
        }
      }
    ]
  }
}
